{
  "name": "extension",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "root": "apps/extension",
  "sourceRoot": "apps/extension/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build",
        "cwd": "apps/extension"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build --watch",
        "cwd": "apps/extension"
      }
    }
  }
}
